PORT=3000

# Postgres connection string
# Local dev example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inferix?schema=public
# Railway prod example:
# DATABASE_URL=postgresql://postgres:PASSWORD@containers-us-west-XXX.railway.app:PORT/railway
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inferix?schema=public

# Provider API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
MISTRAL_API_KEY=...
GROQ_API_KEY=gsk_...

# Inferix master key (clients must send this as Bearer token)
INFERIX_API_KEY=inferix-...

# Dashboard auth + API forwarding
DASHBOARD_PASSWORD=changeme
INFERIX_BASE_URL=http://localhost:3000

# Optional Redis for semantic cache embeddings/TTL in production
REDIS_URL=redis://localhost:6379
