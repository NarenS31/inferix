generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]

}

datasource db {
  provider  = "postgresql"
}

enum Plan {
  FREE
  STARTER
  GROWTH
  SCALE
}

model User {
  id                     String   @id @default(uuid()) @db.Uuid
  email                  String   @unique
  passwordHash           String
  name                   String?
  createdAt              DateTime @default(now())
  plan                   Plan     @default(FREE)
  stripeCustomerId       String?
  stripeSubscriptionId   String?

  apiKeys  ApiKey[]

  @@index([email])
}

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  key         String    @unique
  name        String    @default("Default")
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  active      Boolean   @default(true)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

model RequestLog {
  id               String   @id @default(uuid()) @db.Uuid
  createdAt        DateTime @default(now())
  provider         String
  requestedModel   String?
  model            String
  endpoint         String   @default("untagged")
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costUsd          Float
  latencyMs        Int
  streaming        Boolean
  statusCode       Int
  userId           String
  error            String?
  cacheHit         Boolean  @default(false)
  cacheSimilarity  Float?

  @@index([createdAt])
  @@index([provider])
  @@index([userId])
  @@index([requestedModel])
  @@index([cacheHit])
}

model Cache {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String
  endpointTag     String
  promptHash      String
  promptEmbedding Float[]
  response        String   @db.Text
  model           String
  provider        String
  hitCount        Int      @default(0)
  createdAt       DateTime @default(now())
  expiresAt       DateTime?

  @@index([userId, endpointTag])
  @@index([userId, promptHash])
  @@index([expiresAt])
}

model CacheSetting {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String
  endpointTag         String   @default("*")
  ttlSeconds          Int      @default(86400)
  similarityThreshold Float    @default(0.92)
  enabled             Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, endpointTag])
  @@index([userId])
}

model RoutingRule {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String
  endpointTag        String   @default("*")
  preferredModels    String[]
  costCeilingUsd     Float?
  latencyThresholdMs Int?
  maxTokens          Int?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([userId, endpointTag])
  @@index([active])
}

model WaitlistEmail {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
}
